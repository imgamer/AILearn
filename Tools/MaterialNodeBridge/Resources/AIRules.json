			"properties": ["Name", "R", "G", "B", "A"]
		},
		{
			"type": "TextureSampleParameter2D",
			"description": "Texture parameter for material instance",
			"inputs": ["UVs"],
			"outputs": ["RGB", "A"],
			"properties": ["Name"]
		},
		{
			"type": "Fresnel",
			"description": "Fresnel effect for rim lighting",
			"inputs": ["BaseMaterialExp"],
			"outputs": ["Output"]
		},
		{
			"type": "BumpOffset",
			"description": "Parallax mapping",
			"inputs": ["Coordinate", "Height", "HeightRatio"],
			"outputs": ["Offset"]
		},
		{
			"type": "Panner",
			"description": "Pan texture coordinates",
			"inputs": ["Coordinate", "Time"],
			"outputs": ["Output"]
		},
		{
			"type": "Rotator",
			"description": "Rotate texture coordinates",
			"inputs": ["Coordinate", "Time"],
			"outputs": ["Output"]
		},
		{
			"type": "Time",
			"description": "Time source for animations",
			"inputs": [],
			"outputs": ["Output"]
		},
		{
			"type": "If",
			"description": "Conditional expression",
			"inputs": ["A", "B", "AGreaterThanB", "AEqualsB", "ALessThanB"],
			"outputs": ["Output"]
		},
		{
			"type": "Lerp",
			"description": "Linear interpolation",
			"inputs": ["A", "B", "Alpha"],
			"outputs": ["Output"]
		}
	]
}
