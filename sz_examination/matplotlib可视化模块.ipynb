   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# 数据\n",
    "x = [1, 2, 3, 4]\n",
    "y = [10, 20, 25, 30]\n",
    "\n",
    "plt.figure()\n",
    "plt.plot(x, y)\n",
    "\n",
    "# 添加标题和标签\n",
    "plt.title('Simple Line Plot')\n",
    "plt.xlabel('X Axis')\n",
    "plt.ylabel('Y Axis')\n",
    "\n",
    "# 显示图形\n",
    "plt.show()\n"
   ]
